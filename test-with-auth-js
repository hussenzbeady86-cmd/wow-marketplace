const http = require('http');

// 1. بيانات التسجيل (تحتاج الاسم)
const registerData = JSON.stringify({
  name: 'Seller User',
  email: 'seller@example.com',
  password: 'Password123'
});

// 2. بيانات تسجيل الدخول (لا تحتاج الاسم)
const loginData = JSON.stringify({
  email: 'seller@example.com',
  password: 'Password123'
});

// 3. بيانات الخدمة (تمت إضافة الحقول المطلوبة في الـ Schema الخاص بك)
const serviceData = JSON.stringify({
  title: "WoW Retail Gold - 500,000 Gold",
  description: "Fast delivery on EU-Kazzak server.",
  category: "Gold",        // حقل إلزامي
  price: 35.50,            // حقل إلزامي
  region: "EU"             // حقل إلزامي (يجب أن يكون EU أو US)
});

// دالة موحدة لإرسال الطلبات
const sendReq = (path, method, data, token = null) => {
  return new Promise((resolve) => {
    const options = {
      hostname: '127.0.0.1',
      port: 3000,
      path: path,
      method: method,
      headers: {
        'Content-Type': 'application/json',
        'Authorization': token ? `Bearer ${token}` : '',
        'Content-Length': Buffer.byteLength(data)
      }
    };
    const req = http.request(options, (res) => {
      let body = '';
      res.on('data', (chunk) => { body += chunk; });
      res.on('end', () => {
        try { resolve({ status: res.statusCode, data: JSON.parse(body) }); }
        catch (e) { resolve({ status: res.statusCode, data: body }); }
      });
    });
    req.write(data);
    req.end();
  });
};

async function runFullTest() {
  console.log('--- 1. Registering new user ---');
  await sendReq('/v1/auth/register', 'POST', registerData);

  console.log('--- 2. Logging in to get Token ---');
  const loginRes = await sendReq('/v1/auth/login', 'POST', loginData);
  
  if (loginRes.status !== 200) {
    console.log('Login failed:', loginRes.data);
    return;
  }

  const token = loginRes.data.tokens.access.token;
  console.log('--- 3. Posting service with real Token ---');
  const serviceRes = await sendReq('/v1/services', 'POST', serviceData, token);
  
  console.log('Final Result Status:', serviceRes.status);
  console.log('Service Data Saved:', serviceRes.data);
}

runFullTest();